# Copy this file to .env and fill in your values.
# .env is gitignored and stays on your local machine only.

# The Gmail address (ideally a dedicated business account, not personal Gmail).
GMAIL_ADDRESS=mcpdone.inbox@gmail.com

# 16-character App Password generated at https://myaccount.google.com/apppasswords
# Spaces are optional; "abcd efgh ijkl mnop" and "abcdefghijklmnop" both work.
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Gmail label to scope access to. Create this label in Gmail + a filter that
# auto-applies it to emails addressed to hello@mcpdone.com (or your business
# domain). The server will REFUSE to read emails outside this label.
GMAIL_LABEL=mcpdone-inbox

# Optional — usually leave as defaults.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# Gmail's drafts folder. Default works for English Gmail accounts.
# Localised accounts may need adjustment (e.g., '[Gmail]/Brouillons' for French).
DRAFTS_FOLDER=[Gmail]/Drafts
